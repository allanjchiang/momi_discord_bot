# Copy to .env and paste your bot token from https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=

# Optional: comma-separated server IDs (Developer Mode → right-click server → Copy Server ID).
# Slash commands sync to each guild immediately instead of waiting up to ~1 hour for global sync.
DISCORD_GUILD_ID=1486382154978955417,1078705398401478677
